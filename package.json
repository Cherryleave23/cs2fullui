{
  "name": "cs2-alchemy-manager",
  "version": "1.0.0",
  "description": "CS2炼金管理 — 本地桌面应用，用于CS2物品库存管理、汰换交易模拟与执行、价格数据管理",
  "main": "./out/main/index.js",
  "author": "CS2 Trade Tool",
  "license": "MIT",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "build:win": "npm run build && electron-builder --win",
    "test": "vitest run",
    "test:watch": "vitest",
    "download:csgoapi": "tsx scripts/download-csgoapi.ts"
  },
  "dependencies": {
    "@ant-design/icons": "^5.5.0",
    "antd": "^5.22.0",
    "dayjs": "^1.11.0",
    "echarts": "^5.5.0",
    "echarts-for-react": "^3.0.0",
    "electron-log": "^5.2.0",
    "globaloffensive": "^3.3.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "react-router-dom": "^6.28.0",
    "sql.js": "^1.11.0",
    "steam-session": "^1.9.0",
    "steam-totp": "^2.1.0",
    "steam-user": "^5.0.0",
    "zustand": "^4.5.0"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "electron": "^30.4.0",
    "electron-builder": "^25.1.0",
    "electron-vite": "^2.3.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vite": "^5.4.0",
    "vitest": "^2.1.0"
  },
  "build": {
    "appId": "com.cs2tool.alchemy-manager",
    "productName": "CS2炼金管理",
    "directories": {
      "output": "release"
    },
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "resources/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "unicode": true,
      "language": "2052"
    },
    "files": [
      "out/**/*",
      "resources/**/*"
    ],
    "extraResources": [
      {
        "from": "data/",
        "to": "data/",
        "filter": [
          "**/*"
        ]
      }
    ]
  }
}
